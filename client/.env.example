# ── Client environment variables ──────────────────────────────────────────
# Copy this file to .env and fill in your own values.

# Base URL of the API. Leave empty to use relative paths (same origin).
VITE_API_URL=

# Email allowed to see the testimonial moderation UI. Must match the server's
# ADMIN_EMAIL. The server enforces the real check — this only gates the UI.
VITE_ADMIN_EMAIL=atharvanaik026@gmail.com
