# ── Server environment variables ──────────────────────────────────────────
# Copy this file to .env and fill in your own values.

# Core
PORT=5000
MONGODB_URI=your-mongodb-connection-string
CLIENT_URL=http://localhost:5173

# Auth (Google OAuth via Passport)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback
SESSION_SECRET=a-long-random-string
COOKIE_SECURE=false

# Encryption for stored API keys (AES-256)
ENCRYPTION_KEY=your-32-byte-encryption-key

# Coral / GitHub / Groq / Slack
CORAL_PATH=/path/to/coral
GITHUB_TOKEN=your-github-token
GROQ_API_KEY=your-groq-api-key
GROQ_CHAT_KEY=your-groq-chat-key
SLACK_TOKEN=xoxb-your-slack-token

# Email (Nodemailer via Gmail) — used for welcome + feedback emails
EMAIL_USER=youraddress@gmail.com
EMAIL_PASS=your-gmail-app-password

# Admin — email allowed to moderate testimonials (must match a logged-in user)
ADMIN_EMAIL=atharvanaik026@gmail.com

# Sentry error monitoring — leave empty to disable (e.g. local dev)
SENTRY_DSN=
